{
  "name": "p-ec3-frontend",
  "version": "1.0.0",
  "description": "Frontend Vue 3 + TypeScript para Simulador de Descargas Concurrentes - EC3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "tsx src/backend/server.ts",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:integration": "vitest run --config vitest.integration.config.ts src/frontend/__tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit:backend": "vitest run src/backend",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "chart.js": "^4.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pinia": "^2.1.7",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^3.52.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "vue": "^3.4.27",
    "vue-chartjs": "^5.3.1",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.8",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitest/ui": "^1.6.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.26.0",
    "jsdom": "^24.1.0",
    "msw": "^2.3.1",
    "sass": "^1.77.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.3.1",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.21"
  }
}
