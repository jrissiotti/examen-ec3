{
  "name": "p-ec3-frontend",
  "version": "1.0.0",
  "description": "Frontend Vue 3 + TypeScript para Simulador de Descargas Concurrentes - EC3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:integration": "vitest run src/frontend/__tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit:backend": "vitest run src/backend",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix"
  },
  "dependencies": {
    "vue": "^3.4.27",
    "vue-router": "^4.3.2",
    "pinia": "^2.1.7",
    "axios": "^1.7.2",
    "primevue": "^3.52.0",
    "primeicons": "^7.0.0",
    "primeflex": "^3.3.1",
    "chart.js": "^4.4.3",
    "vue-chartjs": "^5.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "vite": "^5.3.1",
    "typescript": "^5.5.2",
    "vue-tsc": "^2.0.21",
    "@vue/tsconfig": "^0.5.1",
    "vitest": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.1.0",
    "@playwright/test": "^1.44.1",
    "msw": "^2.3.1",
    "@types/node": "^20.14.8",
    "sass": "^1.77.6",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint-plugin-vue": "^9.26.0"
  }
}
